    "@id" : "https://w3id.org/rdip/1.0.0/"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.0.0"
  } ]
}, {
  "@id" : "https://w3id.org/rdip/ComputingEnvironment",
