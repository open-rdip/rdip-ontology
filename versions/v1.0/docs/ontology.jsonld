  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "A project-centric ontology for representing the research lifecycle, provenance, and contextual links between activities, software, and datasets."
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@language" : "en",
    "@value" : "RDIP: Research Data Intelligence Platform Ontology"
  } ],
