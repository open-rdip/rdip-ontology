    <!-- https://w3id.org/rdip/ResearchProject -->


    <owl:Class rdf:about="https://w3id.org/rdip/ResearchProject">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment>A research project that groups together activities, participants and outputs such as datasets, software and publications.</rdfs:comment>
        <rdfs:label>Research project</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/RoleInActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/RoleInActivity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Role"/>
        <rdfs:comment>The specific role that a person has within a particular research activity.</rdfs:comment>
        <rdfs:label>Role in activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/SoftwareApplication -->


