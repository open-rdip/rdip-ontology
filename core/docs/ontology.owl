    <owl:Class rdf:about="https://schema.org/Observation"/>
    


    <!-- https://schema.org/Organization -->


    <owl:Class rdf:about="https://schema.org/Organization"/>
    


    <!-- https://schema.org/Person -->


    <owl:Class rdf:about="https://schema.org/Person"/>
    


    <!-- https://schema.org/Project -->


    <owl:Class rdf:about="https://schema.org/Project">
        <owl:equivalentClass rdf:resource="https://w3id.org/rdip/ResearchProject"/>
    </owl:Class>
    


