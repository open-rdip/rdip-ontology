    <!-- http://purl.org/ontology/bibo/Article -->


    <owl:Class rdf:about="http://purl.org/ontology/bibo/Article">
        <rdfs:subClassOf rdf:resource="https://schema.org/ScholarlyArticle"/>
    </owl:Class>
    


    <!-- http://vivoweb.org/ontology/core#Organization -->


    <owl:Class rdf:about="http://vivoweb.org/ontology/core#Organization">
        <owl:equivalentClass rdf:resource="https://schema.org/Organization"/>
    </owl:Class>
    


    <!-- http://vivoweb.org/ontology/core#Person -->


    <owl:Class rdf:about="http://vivoweb.org/ontology/core#Person">
        <owl:equivalentClass rdf:resource="https://schema.org/Person"/>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/dcat#Dataset -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Dataset">
        <owl:equivalentClass rdf:resource="https://schema.org/Dataset"/>
    </owl:Class>
    


    <!-- https://schema.org/Action -->


    <owl:Class rdf:about="https://schema.org/Action"/>
    


