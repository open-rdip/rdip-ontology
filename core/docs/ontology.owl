    <!-- https://schema.org/SoftwareApplication -->


    <owl:Class rdf:about="https://schema.org/SoftwareApplication">
        <owl:equivalentClass rdf:resource="https://w3id.org/rdip/SoftwareApplication"/>
    </owl:Class>
    


    <!-- https://schema.org/Thing -->


    <owl:Class rdf:about="https://schema.org/Thing"/>
    


    <!-- https://w3id.org/rdip/ActivityAssociation -->


    <owl:Class rdf:about="https://w3id.org/rdip/ActivityAssociation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Association"/>
        <rdfs:comment xml:lang="en">A qualified PROV-O association node linking a ResearchActivity to an agent (Person or Organization) with an explicit RoleInActivity. Use prov:qualifiedAssociation on the activity to point to this node, then prov:agent and prov:hadRole on the node itself. This pattern replaces the simpler rdip:hasActivityRole + rdip:rolePerformedBy chain for full PROV-O compliance.</rdfs:comment>
        <rdfs:label xml:lang="en">Activity association</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/ComputingEnvironment -->


    <owl:Class rdf:about="https://w3id.org/rdip/ComputingEnvironment">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Thing"/>
        <rdfs:comment xml:lang="en">The full hardware and software context in which a computational activity was executed. Records OS version, CPU/GPU hardware, RAM, and links to a machine-actionable environment specification (e.g. a Docker image digest, conda environment.yml, or Nix flake). Essential for computational reproducibility.</rdfs:comment>
        <rdfs:label xml:lang="en">Computing environment</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/DataAnalysisActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/DataAnalysisActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that analyse datasets to derive results, statistics, models or other derived knowledge artefacts. Use rdip:generatesResult to link to EvaluationResult instances.</rdfs:comment>
        <rdfs:label xml:lang="en">Data analysis activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/DataCollectionActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/DataCollectionActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that collect or capture raw data, such as experiments, surveys, interviews, observations or sensor measurements.</rdfs:comment>
        <rdfs:label xml:lang="en">Data collection activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/DataPreservationActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/DataPreservationActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that preserve datasets for the long term, including archiving and embargo management.</rdfs:comment>
        <rdfs:label xml:lang="en">Data preservation activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/DataProcessingActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/DataProcessingActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that clean, transform, integrate, anonymise or otherwise modify existing datasets. The input/output datasets should be linked via rdip:derivedFrom.</rdfs:comment>
        <rdfs:label xml:lang="en">Data processing activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/DataProductionActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/DataProductionActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that produce one or more datasets from instruments, simulations or integrated data pipelines.</rdfs:comment>
        <rdfs:label xml:lang="en">Data production activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/DataPublishingActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/DataPublishingActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that publish or share datasets, e.g. depositing into repositories.</rdfs:comment>
        <rdfs:label xml:lang="en">Data publishing activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/EnvironmentSpec -->


    <owl:Class rdf:about="https://w3id.org/rdip/EnvironmentSpec">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A machine-actionable specification that fully describes a reproducible software environment: e.g. a Docker image (with SHA256 digest), a conda environment.yml, a requirements.txt, or a Nix flake.lock. Link from rdip:ComputingEnvironment via rdip:hasEnvironmentSpec.</rdfs:comment>
        <rdfs:label xml:lang="en">Environment specification</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/EvaluationResult -->


    <owl:Class rdf:about="https://w3id.org/rdip/EvaluationResult">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Observation"/>
        <rdfs:comment xml:lang="en">A quantitative or qualitative result produced by a DataAnalysisActivity. Captures a named metric and its value so that a reproducer can verify their re-run matches the original (e.g. metricName=&apos;accuracy&apos;, metricValue=&apos;0.9432&apos;, splitLabel=&apos;test&apos;). Link from activity via rdip:generatesResult.</rdfs:comment>
        <rdfs:label xml:lang="en">Evaluation result</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/Method -->


    <owl:Class rdf:about="https://w3id.org/rdip/Method">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Plan"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:comment xml:lang="en">A formal method, protocol or workflow specification followed by one or more research activities. Should include a reference (DOI or URL) to an external protocol document and, where applicable, a link to a formal workflow language representation (CWL, Nextflow, Snakemake).</rdfs:comment>
        <rdfs:label xml:lang="en">Research method or protocol</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/Parameter -->


    <owl:Class rdf:about="https://w3id.org/rdip/Parameter">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/PropertyValue"/>
        <rdfs:comment xml:lang="en">A specific setting, hyperparameter or configuration value used to control an activity. Typical examples: learning_rate=0.001, batch_size=32, optimizer=&apos;Adam&apos;, num_epochs=100, train_split=0.8. Use rdip:parameterName for the key and rdip:parameterValue for the value.</rdfs:comment>
        <rdfs:label xml:lang="en">Research parameter</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/PlanningActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/PlanningActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities concerned with planning and designing research, including study design, protocol development, ethical review preparation and DMP writing.</rdfs:comment>
        <rdfs:label xml:lang="en">Planning activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/PublicationActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/PublicationActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that produce scholarly publications such as journal articles, preprints, book chapters or technical reports.</rdfs:comment>
        <rdfs:label xml:lang="en">Publication activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/RandomSeed -->


    <owl:Class rdf:about="https://w3id.org/rdip/RandomSeed">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/Parameter"/>
        <rdfs:comment xml:lang="en">A special Parameter subclass for random seed values. Explicitly typed because stochastic reproducibility depends critically on recording the exact seed used in all random number generators (NumPy, PyTorch, Python random, CUDA). Set rdip:parameterName=&apos;random_seed&apos; and rdip:parameterValue to the integer seed string.</rdfs:comment>
        <rdfs:label xml:lang="en">Random seed</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/ResearchActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/ResearchActivity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Action"/>
        <rdfs:comment xml:lang="en">Any discrete activity in the research lifecycle, including planning, data collection, processing, analysis, publishing and preservation. Subclass of prov:Activity so that all PROV-O properties (wasAssociatedWith, used, generated, wasInformedBy, qualifiedAssociation) are directly applicable.</rdfs:comment>
        <rdfs:label xml:lang="en">Research activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/ResearchProject -->


    <owl:Class rdf:about="https://w3id.org/rdip/ResearchProject">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A research project that groups together activities, participants and outputs such as datasets, software and publications. Equivalent to schema:Project and treated as a PROV Entity so that provenance can be attributed at project level.</rdfs:comment>
        <rdfs:label xml:lang="en">Research project</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/RoleInActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/RoleInActivity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Role"/>
        <rdfs:comment xml:lang="en">The specific role that a person plays within a particular research activity, e.g. &apos;Principal Investigator&apos;, &apos;Data Curator&apos;, &apos;Software Engineer&apos;, &apos;Annotator&apos;. Attach via rdip:ActivityAssociation using the qualified PROV-O pattern.</rdfs:comment>
        <rdfs:label xml:lang="en">Role in activity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/SoftwareApplication -->


    <owl:Class rdf:about="https://w3id.org/rdip/SoftwareApplication">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">Software or computational tools used during research activities or produced as outputs. This includes scripts, libraries, ML frameworks, workflow engines and compiled programs. Version is captured via rdip:version; dependencies via rdip:softwareDependency; execution environment via rdip:ComputingEnvironment.</rdfs:comment>
        <rdfs:label xml:lang="en">Research software</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/SoftwareDependency -->


    <owl:Class rdf:about="https://w3id.org/rdip/SoftwareDependency">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A specific versioned library or package required by a SoftwareApplication at runtime or build time (e.g. &apos;torch==2.1.0&apos;, &apos;numpy&gt;=1.24&apos;). Captures the exact version string and the dependency type (runtime, build, optional) to enable exact environment reconstruction.</rdfs:comment>
        <rdfs:label xml:lang="en">Software dependency</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rdip/SoftwareDevelopmentActivity -->


    <owl:Class rdf:about="https://w3id.org/rdip/SoftwareDevelopmentActivity">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rdip/ResearchActivity"/>
        <rdfs:comment xml:lang="en">Activities that design, implement, test or maintain research software. Links to rdip:SoftwareApplication via rdip:generatesSoftware.</rdfs:comment>
        <rdfs:label xml:lang="en">Software development activity</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="https://w3id.org/rdip/dataFormat">
        <rdfs:comment xml:lang="en">The primary file format of the dataset, e.g. &apos;CSV&apos;, &apos;Parquet&apos;, &apos;HDF5&apos;, &apos;JSON-L&apos;. Recommended to use IANA media type strings.</rdfs:comment>
        <rdfs:label xml:lang="en">data format</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/rdip/dataLicense">
        <rdfs:comment xml:lang="en">URI of the licence under which this dataset is released, e.g. &lt;https://creativecommons.org/licenses/by/4.0/&gt;. Machine-readable licence URIs are required for access validation during reproduction.</rdfs:comment>
        <rdfs:label xml:lang="en">data license</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/rdip/dependencyName">
        <rdfs:comment xml:lang="en">The package/library name of this dependency, e.g. &apos;torch&apos;, &apos;numpy&apos;, &apos;scikit-learn&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">dependency name</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/rdip/metricName">
        <rdfs:comment xml:lang="en">The name of the evaluation metric, e.g. &apos;accuracy&apos;, &apos;F1-macro&apos;, &apos;RMSE&apos;, &apos;AUC-ROC&apos;, &apos;BLEU&apos;, &apos;perplexity&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">metric name</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/rdip/parameterName">
        <rdfs:comment xml:lang="en">The key/name of the parameter, e.g. &apos;learning_rate&apos;, &apos;batch_size&apos;, &apos;optimizer&apos;, &apos;num_layers&apos;, &apos;dropout_rate&apos;, &apos;random_seed&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">parameter name</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/rdip/roleLabel">
        <rdfs:comment xml:lang="en">Human-readable label for the role, e.g. &apos;Principal Investigator&apos;, &apos;Data Curator&apos;, &apos;Annotator&apos;, &apos;Software Engineer&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">role label</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/rdip/softwareLicense">
        <rdfs:comment xml:lang="en">URI of the open-source licence for this software, e.g. &lt;https://opensource.org/licenses/MIT&gt;.</rdfs:comment>
        <rdfs:label xml:lang="en">software license</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/rdip/title">
        <rdfs:comment xml:lang="en">The human-readable title or name of the entity.</rdfs:comment>
        <rdfs:label xml:lang="en">title</rdfs:label>
    </rdf:Description>
</rdf:RDF>



