<https://schema.org/CreativeWork> rdf:type owl:Class .


###  https://schema.org/Dataset
<https://schema.org/Dataset> rdf:type owl:Class .


###  https://schema.org/Observation
<https://schema.org/Observation> rdf:type owl:Class .


###  https://schema.org/Organization
<https://schema.org/Organization> rdf:type owl:Class .


###  https://schema.org/Person
<https://schema.org/Person> rdf:type owl:Class .


###  https://schema.org/Project
<https://schema.org/Project> rdf:type owl:Class ;
                             owl:equivalentClass :ResearchProject .


###  https://schema.org/PropertyValue
<https://schema.org/PropertyValue> rdf:type owl:Class .


###  https://schema.org/ScholarlyArticle
<https://schema.org/ScholarlyArticle> rdf:type owl:Class .


###  https://schema.org/SoftwareApplication
<https://schema.org/SoftwareApplication> rdf:type owl:Class ;
                                         owl:equivalentClass :SoftwareApplication .


###  https://schema.org/Thing
<https://schema.org/Thing> rdf:type owl:Class .


###  https://w3id.org/rdip/ActivityAssociation
:ActivityAssociation rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.w3.org/ns/prov#Association> ;
                     rdfs:comment "A qualified PROV-O association node linking a ResearchActivity to an agent (Person or Organization) with an explicit RoleInActivity. Use prov:qualifiedAssociation on the activity to point to this node, then prov:agent and prov:hadRole on the node itself. This pattern replaces the simpler rdip:hasActivityRole + rdip:rolePerformedBy chain for full PROV-O compliance."@en ;
                     rdfs:label "Activity association"@en .


###  https://w3id.org/rdip/ComputingEnvironment
:ComputingEnvironment rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ,
                                      <https://schema.org/Thing> ;
                      rdfs:comment "The full hardware and software context in which a computational activity was executed. Records OS version, CPU/GPU hardware, RAM, and links to a machine-actionable environment specification (e.g. a Docker image digest, conda environment.yml, or Nix flake). Essential for computational reproducibility."@en ;
                      rdfs:label "Computing environment"@en .


###  https://w3id.org/rdip/DataAnalysisActivity
:DataAnalysisActivity rdf:type owl:Class ;
                      rdfs:subClassOf :ResearchActivity ;
                      rdfs:comment "Activities that analyse datasets to derive results, statistics, models or other derived knowledge artefacts. Use rdip:generatesResult to link to EvaluationResult instances."@en ;
                      rdfs:label "Data analysis activity"@en .


###  https://w3id.org/rdip/DataCollectionActivity
:DataCollectionActivity rdf:type owl:Class ;
                        rdfs:subClassOf :ResearchActivity ;
                        rdfs:comment "Activities that collect or capture raw data, such as experiments, surveys, interviews, observations or sensor measurements."@en ;
                        rdfs:label "Data collection activity"@en .


###  https://w3id.org/rdip/DataPreservationActivity
:DataPreservationActivity rdf:type owl:Class ;
                          rdfs:subClassOf :ResearchActivity ;
                          rdfs:comment "Activities that preserve datasets for the long term, including archiving and embargo management."@en ;
                          rdfs:label "Data preservation activity"@en .


###  https://w3id.org/rdip/DataProcessingActivity
:DataProcessingActivity rdf:type owl:Class ;
                        rdfs:subClassOf :ResearchActivity ;
                        rdfs:comment "Activities that clean, transform, integrate, anonymise or otherwise modify existing datasets. The input/output datasets should be linked via rdip:derivedFrom."@en ;
                        rdfs:label "Data processing activity"@en .


###  https://w3id.org/rdip/DataProductionActivity
:DataProductionActivity rdf:type owl:Class ;
                        rdfs:subClassOf :ResearchActivity ;
                        rdfs:comment "Activities that produce one or more datasets from instruments, simulations or integrated data pipelines."@en ;
                        rdfs:label "Data production activity"@en .


###  https://w3id.org/rdip/DataPublishingActivity
:DataPublishingActivity rdf:type owl:Class ;
                        rdfs:subClassOf :ResearchActivity ;
                        rdfs:comment "Activities that publish or share datasets, e.g. depositing into repositories."@en ;
                        rdfs:label "Data publishing activity"@en .


###  https://w3id.org/rdip/EnvironmentSpec
:EnvironmentSpec rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                 rdfs:comment "A machine-actionable specification that fully describes a reproducible software environment: e.g. a Docker image (with SHA256 digest), a conda environment.yml, a requirements.txt, or a Nix flake.lock. Link from rdip:ComputingEnvironment via rdip:hasEnvironmentSpec."@en ;
                 rdfs:label "Environment specification"@en .


###  https://w3id.org/rdip/EvaluationResult
:EvaluationResult rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ,
                                  <https://schema.org/Observation> ;
                  rdfs:comment "A quantitative or qualitative result produced by a DataAnalysisActivity. Captures a named metric and its value so that a reproducer can verify their re-run matches the original (e.g. metricName='accuracy', metricValue='0.9432', splitLabel='test'). Link from activity via rdip:generatesResult."@en ;
                  rdfs:label "Evaluation result"@en .


###  https://w3id.org/rdip/Method
:Method rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Plan> ,
                        <https://schema.org/CreativeWork> ;
        rdfs:comment "A formal method, protocol or workflow specification followed by one or more research activities. Should include a reference (DOI or URL) to an external protocol document and, where applicable, a link to a formal workflow language representation (CWL, Nextflow, Snakemake)."@en ;
        rdfs:label "Research method or protocol"@en .


###  https://w3id.org/rdip/Parameter
:Parameter rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ,
                           <https://schema.org/PropertyValue> ;
           rdfs:comment "A specific setting, hyperparameter or configuration value used to control an activity. Typical examples: learning_rate=0.001, batch_size=32, optimizer='Adam', num_epochs=100, train_split=0.8. Use rdip:parameterName for the key and rdip:parameterValue for the value."@en ;
           rdfs:label "Research parameter"@en .


###  https://w3id.org/rdip/PlanningActivity
:PlanningActivity rdf:type owl:Class ;
                  rdfs:subClassOf :ResearchActivity ;
                  rdfs:comment "Activities concerned with planning and designing research, including study design, protocol development, ethical review preparation and DMP writing."@en ;
                  rdfs:label "Planning activity"@en .


###  https://w3id.org/rdip/PublicationActivity
:PublicationActivity rdf:type owl:Class ;
                     rdfs:subClassOf :ResearchActivity ;
                     rdfs:comment "Activities that produce scholarly publications such as journal articles, preprints, book chapters or technical reports."@en ;
                     rdfs:label "Publication activity"@en .


###  https://w3id.org/rdip/RandomSeed
:RandomSeed rdf:type owl:Class ;
            rdfs:subClassOf :Parameter ;
            rdfs:comment "A special Parameter subclass for random seed values. Explicitly typed because stochastic reproducibility depends critically on recording the exact seed used in all random number generators (NumPy, PyTorch, Python random, CUDA). Set rdip:parameterName='random_seed' and rdip:parameterValue to the integer seed string."@en ;
            rdfs:label "Random seed"@en .


###  https://w3id.org/rdip/ResearchActivity
:ResearchActivity rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ,
                                  <https://schema.org/Action> ;
                  rdfs:comment "Any discrete activity in the research lifecycle, including planning, data collection, processing, analysis, publishing and preservation. Subclass of prov:Activity so that all PROV-O properties (wasAssociatedWith, used, generated, wasInformedBy, qualifiedAssociation) are directly applicable."@en ;
                  rdfs:label "Research activity"@en .


###  https://w3id.org/rdip/ResearchProject
:ResearchProject rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                 rdfs:comment "A research project that groups together activities, participants and outputs such as datasets, software and publications. Equivalent to schema:Project and treated as a PROV Entity so that provenance can be attributed at project level."@en ;
                 rdfs:label "Research project"@en .


###  https://w3id.org/rdip/RoleInActivity
:RoleInActivity rdf:type owl:Class ;
                rdfs:subClassOf <http://www.w3.org/ns/prov#Role> ;
                rdfs:comment "The specific role that a person plays within a particular research activity, e.g. 'Principal Investigator', 'Data Curator', 'Software Engineer', 'Annotator'. Attach via rdip:ActivityAssociation using the qualified PROV-O pattern."@en ;
                rdfs:label "Role in activity"@en .


###  https://w3id.org/rdip/SoftwareApplication
:SoftwareApplication rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                     rdfs:comment "Software or computational tools used during research activities or produced as outputs. This includes scripts, libraries, ML frameworks, workflow engines and compiled programs. Version is captured via rdip:version; dependencies via rdip:softwareDependency; execution environment via rdip:ComputingEnvironment."@en ;
                     rdfs:label "Research software"@en .


###  https://w3id.org/rdip/SoftwareDependency
:SoftwareDependency rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                    rdfs:comment "A specific versioned library or package required by a SoftwareApplication at runtime or build time (e.g. 'torch==2.1.0', 'numpy>=1.24'). Captures the exact version string and the dependency type (runtime, build, optional) to enable exact environment reconstruction."@en ;
                    rdfs:label "Software dependency"@en .


###  https://w3id.org/rdip/SoftwareDevelopmentActivity
:SoftwareDevelopmentActivity rdf:type owl:Class ;
                             rdfs:subClassOf :ResearchActivity ;
                             rdfs:comment "Activities that design, implement, test or maintain research software. Links to rdip:SoftwareApplication via rdip:generatesSoftware."@en ;
                             rdfs:label "Software development activity"@en .


#################################################################
#    Annotations
#################################################################

:dataFormat rdfs:comment "The primary file format of the dataset, e.g. 'CSV', 'Parquet', 'HDF5', 'JSON-L'. Recommended to use IANA media type strings."@en ;
            rdfs:label "data format"@en .


:dataLicense rdfs:comment "URI of the licence under which this dataset is released, e.g. <https://creativecommons.org/licenses/by/4.0/>. Machine-readable licence URIs are required for access validation during reproduction."@en ;
             rdfs:label "data license"@en .


:dependencyName rdfs:comment "The package/library name of this dependency, e.g. 'torch', 'numpy', 'scikit-learn'."@en ;
                rdfs:label "dependency name"@en .


:metricName rdfs:comment "The name of the evaluation metric, e.g. 'accuracy', 'F1-macro', 'RMSE', 'AUC-ROC', 'BLEU', 'perplexity'."@en ;
            rdfs:label "metric name"@en .


:parameterName rdfs:comment "The key/name of the parameter, e.g. 'learning_rate', 'batch_size', 'optimizer', 'num_layers', 'dropout_rate', 'random_seed'."@en ;
               rdfs:label "parameter name"@en .


:roleLabel rdfs:comment "Human-readable label for the role, e.g. 'Principal Investigator', 'Data Curator', 'Annotator', 'Software Engineer'."@en ;
           rdfs:label "role label"@en .


:softwareLicense rdfs:comment "URI of the open-source licence for this software, e.g. <https://opensource.org/licenses/MIT>."@en ;
                 rdfs:label "software license"@en .


:title rdfs:comment "The human-readable title or name of the entity."@en ;
       rdfs:label "title"@en .


