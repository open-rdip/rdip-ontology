###  https://w3id.org/rdip/hasActivity
<https://w3id.org/rdip/hasActivity> rdf:type owl:ObjectProperty ;
                                    owl:inverseOf <https://w3id.org/rdip/isPartOfProject> ;
                                    rdfs:domain <https://w3id.org/rdip/ResearchProject> ;
                                    rdfs:range <https://w3id.org/rdip/ResearchActivity> ;
                                    rdfs:label "has activity" .


###  https://w3id.org/rdip/hasActivityRole
<https://w3id.org/rdip/hasActivityRole> rdf:type owl:ObjectProperty ;
                                        rdfs:domain <https://w3id.org/rdip/ResearchActivity> ;
                                        rdfs:range <https://w3id.org/rdip/RoleInActivity> ;
                                        rdfs:label "has activity role" .


###  https://w3id.org/rdip/hasLeadOrganization
<https://w3id.org/rdip/hasLeadOrganization> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAssociatedWith> ,
                                                               <https://schema.org/sponsor> ;
                                            rdfs:domain <https://w3id.org/rdip/ResearchProject> ;
                                            rdfs:range <http://vivoweb.org/ontology/core#Organization> ;
                                            rdfs:label "has lead organization" .


###  https://w3id.org/rdip/hasOutput
<https://w3id.org/rdip/hasOutput> rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf <http://www.w3.org/ns/prov#generated> ,
