###  https://w3id.org/rdip/DataAnalysisActivity
<https://w3id.org/rdip/DataAnalysisActivity> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                             rdfs:comment "Activities that analyse datasets to derive results, statistics, models or other derived knowledge artifacts." ;
                                             rdfs:label "Data analysis activity" .


###  https://w3id.org/rdip/DataCollectionActivity
<https://w3id.org/rdip/DataCollectionActivity> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                               rdfs:comment "Activities that collect or capture raw data, such as experiments, surveys, interviews, observations or sensor measurements." ;
                                               rdfs:label "Data collection activity" .


###  https://w3id.org/rdip/DataPreservationActivity
<https://w3id.org/rdip/DataPreservationActivity> rdf:type owl:Class ;
                                                 rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                                 rdfs:comment "Activities that preserve datasets for the long term." ;
                                                 rdfs:label "Data preservation activity" .


###  https://w3id.org/rdip/DataProcessingActivity
<https://w3id.org/rdip/DataProcessingActivity> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                               rdfs:comment "Activities that clean, transform, integrate, anonymize or otherwise modify existing datasets." ;
                                               rdfs:label "Data processing activity" .


###  https://w3id.org/rdip/DataProductionActivity
<https://w3id.org/rdip/DataProductionActivity> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                               rdfs:comment "Activities that produce one or more datasets from instruments, simulations or integrated data pipelines." ;
                                               rdfs:label "Data production activity" .


###  https://w3id.org/rdip/DataPublishingActivity
<https://w3id.org/rdip/DataPublishingActivity> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                               rdfs:comment "Activities that publish or share datasets, e.g. depositing into repositories." ;
                                               rdfs:label "Data publishing activity" .


###  https://w3id.org/rdip/Method
<https://w3id.org/rdip/Method> rdf:type owl:Class ;
                               rdfs:subClassOf <http://www.w3.org/ns/prov#Plan> ,
                                               <https://schema.org/CreativeWork> ;
                               rdfs:comment "A formal method, protocol, or workflow specification followed by one or more research activities." ;
                               rdfs:label "Research method or protocol" .


###  https://w3id.org/rdip/PlanningActivity
<https://w3id.org/rdip/PlanningActivity> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                         rdfs:comment "Activities concerned with planning and designing research, including study design, protocol development and ethical review preparation." ;
                                         rdfs:label "Planning activity" .


###  https://w3id.org/rdip/PublicationActivity
<https://w3id.org/rdip/PublicationActivity> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                            rdfs:comment "Activities that produce scholarly publications such as journal articles." ;
                                            rdfs:label "Publication activity" .


###  https://w3id.org/rdip/ResearchActivity
<https://w3id.org/rdip/ResearchActivity> rdf:type owl:Class ;
                                         rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ,
                                                         <https://schema.org/Action> ;
                                         rdfs:comment "Any activity in the research lifecycle, including planning, data collection, processing, analysis, publishing and preservation." ;
                                         rdfs:label "Research activity" .


###  https://w3id.org/rdip/ResearchProject
<https://w3id.org/rdip/ResearchProject> rdf:type owl:Class ;
                                        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                                        rdfs:comment "A research project that groups together activities, participants and outputs such as datasets, software and publications." ;
                                        rdfs:label "Research project" .


###  https://w3id.org/rdip/RoleInActivity
<https://w3id.org/rdip/RoleInActivity> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://www.w3.org/ns/prov#Role> ;
                                       rdfs:comment "The specific role that a person has within a particular research activity." ;
                                       rdfs:label "Role in activity" .


###  https://w3id.org/rdip/SoftwareApplication
<https://w3id.org/rdip/SoftwareApplication> rdf:type owl:Class ;
                                            rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                                            rdfs:comment "Software or computational tools used during research activities or produced as outputs." ;
                                            rdfs:label "Research software" .


###  https://w3id.org/rdip/SoftwareDevelopmentActivity
<https://w3id.org/rdip/SoftwareDevelopmentActivity> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://w3id.org/rdip/ResearchActivity> ;
                                                    rdfs:comment "Activities that design, implement, test or maintain research software." ;
                                                    rdfs:label "Software development activity" .


