<https://w3id.org/rdip/generatesPublication> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://www.w3.org/ns/prov#generated> ;
                                             rdfs:domain <https://w3id.org/rdip/PublicationActivity> ;
