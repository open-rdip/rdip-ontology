@prefix : <https://w3id.org/rdip/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .

@prefix rdip: <https://w3id.org/rdip/> .
@prefix vivo: <http://vivoweb.org/ontology/core#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix cito: <http://purl.org/spar/cito/> .
@prefix schema: <https://schema.org/> .

<https://w3id.org/rdip> rdf:type owl:Ontology ;
    # --- METADATA FOR WIDOCO ---
    dc:title "RDIP: Research Data Intelligence Platform Ontology"@en ;
    dc:description "A project-centric ontology for representing the research lifecycle, provenance, and contextual links between activities, software, and datasets."@en ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <https://w3id.org/rdip/1.0.0> ;
    vann:preferredNamespacePrefix "rdip" ;
    vann:preferredNamespaceUri "https://w3id.org/rdip/" ;
    # ---------------------------
    rdfs:comment "Core ontology for representing research projects, activities, datasets, software and publications on an open science platform." ;
    owl:imports
        <http://vivoweb.org/ontology/core> ,
        <http://purl.org/ontology/bibo/> ,
        <http://www.w3.org/ns/dcat#> ,
        <http://www.w3.org/ns/prov-o#> ,
        <http://purl.org/spar/cito/> .

#################################################################
# CLASSES
#################################################################

rdip:ResearchProject a owl:Class ;
    owl:equivalentClass schema:Project ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Research project" ;
    rdfs:comment "A research project that groups together activities, participants and outputs such as datasets, software and publications." .

rdip:ResearchActivity a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Research activity" ;
    rdfs:comment "Any activity in the research lifecycle, including planning, data collection, processing, analysis, publishing and preservation." .

rdip:PlanningActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Planning activity" ;
    rdfs:comment "Activities concerned with planning and designing research, including study design, protocol development and ethical review preparation." .

rdip:DataCollectionActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Data collection activity" ;
    rdfs:comment "Activities that collect or capture raw data, such as experiments, surveys, interviews, observations or sensor measurements." .

rdip:DataProductionActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Data production activity" ;
    rdfs:comment "Activities that produce one or more datasets from instruments, simulations or integrated data pipelines." .

rdip:DataProcessingActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Data processing activity" ;
    rdfs:comment "Activities that clean, transform, integrate, anonymize or otherwise modify existing datasets." .

rdip:DataAnalysisActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Data analysis activity" ;
    rdfs:comment "Activities that analyse datasets to derive results, statistics, models or other derived knowledge artifacts." .

rdip:DataPublishingActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Data publishing activity" ;
    rdfs:comment "Activities that publish or share datasets, e.g. depositing into repositories." .

rdip:DataPreservationActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Data preservation activity" ;
    rdfs:comment "Activities that preserve datasets for the long term." .

rdip:PublicationActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Publication activity" ;
    rdfs:comment "Activities that produce scholarly publications such as journal articles." .

rdip:SoftwareDevelopmentActivity a owl:Class ;
    rdfs:subClassOf rdip:ResearchActivity ;
    rdfs:label "Software development activity" ;
    rdfs:comment "Activities that design, implement, test or maintain research software." .

rdip:RoleInActivity a owl:Class ;
    rdfs:subClassOf prov:Role ;
    rdfs:label "Role in activity" ;
    rdfs:comment "The specific role that a person has within a particular research activity." .

rdip:SoftwareApplication a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Research software" ;
    rdfs:comment "Software or computational tools used during research activities or produced as outputs." .

rdip:Method a owl:Class ;
    rdfs:subClassOf prov:Plan ;
    rdfs:label "Research method or protocol" ;
    rdfs:comment "A formal method, protocol, or workflow specification followed by one or more research activities." .

#################################################################
# OBJECT PROPERTIES
#################################################################

rdip:hasActivity a owl:ObjectProperty ;
    owl:inverseOf rdip:isPartOfProject ;
    rdfs:domain rdip:ResearchProject ;
    rdfs:range rdip:ResearchActivity ;
    rdfs:label "has activity" .

rdip:isPartOfProject a owl:ObjectProperty ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range rdip:ResearchProject ;
    rdfs:label "is part of project" .

rdip:hasOutput a owl:ObjectProperty ;
    owl:inverseOf rdip:isOutputOf ;
    rdfs:domain rdip:ResearchProject ;
    rdfs:range prov:Entity ;
    rdfs:label "has output" .

rdip:isOutputOf a owl:ObjectProperty ;
    rdfs:domain prov:Entity ;
    rdfs:range rdip:ResearchProject ;
    rdfs:label "is output of" .

rdip:usedDataset a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range dcat:Dataset ;
    rdfs:label "used dataset" .

rdip:usedSoftware a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range rdip:SoftwareApplication ;
    rdfs:label "used software" .

rdip:hasActivityRole a owl:ObjectProperty ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range rdip:RoleInActivity ;
    rdfs:label "has activity role" .

rdip:rolePerformedBy a owl:ObjectProperty ;
    rdfs:domain rdip:RoleInActivity ;
    rdfs:range vivo:Person ;
    rdfs:label "role performed by" .

rdip:hasParticipant a owl:ObjectProperty ;
    rdfs:domain rdip:ResearchProject ;
    rdfs:range vivo:Person ;
    rdfs:label "has participant" .

rdip:hasLeadOrganization a owl:ObjectProperty ;
    rdfs:domain rdip:ResearchProject ;
    rdfs:range vivo:Organization ;
    rdfs:label "has lead organization" .

rdip:generatesDataset a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:generated ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range dcat:Dataset ;
    rdfs:label "generates dataset" .

rdip:generatesSoftware a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:generated ;
    rdfs:domain rdip:SoftwareDevelopmentActivity ;
    rdfs:range rdip:SoftwareApplication ;
    rdfs:label "generates software" .

rdip:generatesPublication a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:generated ;
    rdfs:domain rdip:PublicationActivity ;
    rdfs:range bibo:Document ;
    rdfs:label "generates publication" .

rdip:isDocumentedBy a owl:ObjectProperty ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range bibo:Document ;
    rdfs:label "is documented by" .

rdip:citesDataset a owl:ObjectProperty ;
    rdfs:subPropertyOf cito:citesAsDataSource ;
    rdfs:domain bibo:Document ;
    rdfs:range dcat:Dataset ;
    rdfs:label "cites dataset" .

rdip:usedMethod a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range  rdip:Method ;
    rdfs:label "used method" .

#################################################################
# DATA PROPERTIES
#################################################################

rdip:identifier a owl:DatatypeProperty ;
    rdfs:subPropertyOf dcterms:identifier, schema:identifier ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "identifier" .

rdip:title a owl:DatatypeProperty ;
    rdfs:subPropertyOf dcterms:title, schema:name ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "title" .

rdip:description a owl:DatatypeProperty ;
    rdfs:subPropertyOf dcterms:description, schema:description ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "description" .

rdip:activityDescription a owl:DatatypeProperty ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range xsd:string ;
    rdfs:label "activity description" .

rdip:roleLabel a owl:DatatypeProperty ;
    rdfs:domain rdip:RoleInActivity ;
    rdfs:range xsd:string ;
    rdfs:label "role label" .

rdip:activityStart a owl:DatatypeProperty ;
    rdfs:subPropertyOf schema:startDate ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range xsd:dateTime ;
    rdfs:label "activity start" .

rdip:activityEnd a owl:DatatypeProperty ;
    rdfs:subPropertyOf schema:endDate ;
    rdfs:domain rdip:ResearchActivity ;
    rdfs:range xsd:dateTime ;
    rdfs:label "activity end" .

rdip:accessLevel a owl:DatatypeProperty ;
    rdfs:subPropertyOf schema:conditionsOfAccess ;
    rdfs:domain dcat:Dataset ;
    rdfs:range xsd:string ;
    rdfs:label "access level" .

rdip:landingPage a owl:DatatypeProperty ;
    rdfs:subPropertyOf dcat:landingPage, schema:url ;
    rdfs:domain dcat:Dataset ;
    rdfs:range xsd:anyURI ;
    rdfs:label "landing page" .

rdip:version a owl:DatatypeProperty ;
    rdfs:subPropertyOf schema:version ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "version" .

rdip:projectStart a owl:DatatypeProperty ;
    rdfs:domain rdip:ResearchProject ;
    rdfs:range xsd:dateTime ;
    rdfs:label "project start" .

rdip:projectEnd a owl:DatatypeProperty ;
    rdfs:domain rdip:ResearchProject ;
    rdfs:range xsd:dateTime ;
    rdfs:label "project end" .

#################################################################
# MAPPINGS TO SCHEMA.ORG & OTHERS
#################################################################

vivo:Person a owl:Class ;
    owl:equivalentClass schema:Person .

vivo:Organization a owl:Class ;
    owl:equivalentClass schema:Organization .

dcat:Dataset a owl:Class ;
    owl:equivalentClass schema:Dataset .

bibo:Article a owl:Class ;
    rdfs:subClassOf schema:ScholarlyArticle .

rdip:ResearchActivity rdfs:subClassOf schema:Action .
rdip:SoftwareApplication owl:equivalentClass schema:SoftwareApplication .
rdip:Method rdfs:subClassOf schema:CreativeWork .

#################################################################
# PROPERTY MAPPINGS (Schema.org & PROV)
#################################################################

# --- Object Property Mappings ---

rdip:hasParticipant rdfs:subPropertyOf schema:contributor, prov:agent .
rdip:hasLeadOrganization rdfs:subPropertyOf schema:sponsor, prov:wasAssociatedWith .
rdip:hasOutput rdfs:subPropertyOf schema:result, prov:generated .
rdip:isOutputOf rdfs:subPropertyOf schema:isPartOf, prov:wasGeneratedBy .

# --- Data Property Mappings ---

rdip:projectStart rdfs:subPropertyOf schema:startDate, prov:startedAtTime .
rdip:projectEnd rdfs:subPropertyOf schema:endDate, prov:endedAtTime .
